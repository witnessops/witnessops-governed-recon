{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://witnessops.example/schemas/tools/draft_scope.input.schema.json",
  "title": "draft_scope input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "seed_domain",
    "methods",
    "exclusions",
    "time_window",
    "jurisdiction"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^dc_[A-Za-z0-9]+$"
    },
    "seed_domain": {
      "type": "string",
      "pattern": "^[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$"
    },
    "methods": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "dns_resolution",
          "certificate_observation",
          "subdomain_discovery",
          "http_fingerprint",
          "email_posture",
          "service_banner_observation"
        ]
      }
    },
    "exclusions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 2,
      "maxLength": 32
    }
  }
}
