{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://witnessops.example/schemas/tools/verify_domain_control.output.schema.json",
  "title": "verify_domain_control output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim",
    "verified",
    "receipts"
  ],
  "properties": {
    "claim": {
      "$ref": "../objects/DomainClaim.schema.json"
    },
    "verified": {
      "type": "boolean"
    },
    "receipts": {
      "type": "array",
      "items": {
        "$ref": "../objects/ReceiptDescriptor.schema.json"
      }
    }
  }
}
