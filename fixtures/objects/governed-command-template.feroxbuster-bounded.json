{
  "template_id": "feroxbuster_bounded_web_discovery",
  "workflow_class_id": "external_ad_exposure_proof_run",
  "tool_name": "feroxbuster",
  "phase": "active_web_discovery",
  "execution_mode": "record_only",
  "requires_authority_gate": true,
  "requires_approved_target": true,
  "requires_active_scan_approval": true,
  "requires_lockout_policy": false,
  "argv_template": ["feroxbuster", "-u", "{target}", "-w", "{wordlist}", "-d", "3", "--filter-status", "404", "-o", "{output_path}"],
  "forbidden_capabilities": [
    "out_of_scope_scanning",
    "unbounded_recursion",
    "unauthorized_authenticated_scan"
  ]
}
